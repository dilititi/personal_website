{
  "name": "chen-personal-site",
  "version": "1.0.0",
  "description": "Personal website for Chen — film student in Hangzhou",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check:security": "npm audit --audit-level=high",
    "check:dist": "node scripts/assert-client-bundle.mjs",
    "check:deploy": "node scripts/check-deploy.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "node --experimental-websocket tests/ui-smoke.mjs",
    "test:ui:preview": "node --experimental-websocket tests/ui-smoke.mjs --preview"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "dependencies": {
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.13.0",
    "@vitejs/plugin-react": "^6.0.4",
    "eslint": "^9.13.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.14",
    "globals": "^15.11.0",
    "prettier": "^3.3.3",
    "vite": "^8.1.5",
    "vite-prerender-plugin": "^0.5.13",
    "vitest": "^4.1.8"
  }
}
